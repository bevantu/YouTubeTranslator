{
  "manifest_version": 3,
  "name": "YouTube Bilingual Subtitles",
  "default_locale": "en",
  "version": "1.0.0",
  "description": "Display bilingual subtitles on YouTube videos with AI-powered translation and vocabulary learning features",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*"
      ],
      "css": [
        "content/content.css"
      ],
      "js": [
        "lib/languages.js",
        "lib/storage.js",
        "content/wordPopup.js",
        "content/panel.js",
        "content/subtitle.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}